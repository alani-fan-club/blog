---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  author: string;
  tags: string[];
  excerpt: string;
}

const { title, date, author, tags, excerpt } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const isoDate = date.toISOString().split('T')[0];
---

<Base title={title} description={excerpt}>
  <article>
    <a href="/" class="back-link">All Posts</a>

    <header class="post-header">
      <time class="post-date" datetime={isoDate}>{formattedDate}</time>
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <span>{author}</span>
        {tags.length > 0 && <span class="separator">//</span>}
        <div class="post-tags">
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </div>
    </header>

    <div class="post-content">
      <slot />
    </div>
  </article>
</Base>
