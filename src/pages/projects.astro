---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Base title="Projects">
  <header class="page-header">
    <h1 class="page-title">Projects</h1>
    <p class="page-subtitle">// Active research initiatives</p>
  </header>

  <div class="project-list">
    {await Promise.all(projects.map(async (project) => {
      const { Content } = await project.render();
      return (
        <article class="project-card">
          <div class="corner-marks"></div>
          <div class="project-status">{project.data.status}</div>
          <h2 class="project-title">{project.data.title}</h2>
          <div class="project-body">
            <Content />
          </div>
          {project.data.targets && (
            <div class="project-targets">{project.data.targets}</div>
          )}
        </article>
      );
    }))}
  </div>
</Base>
