---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Base title="Projects">
  <header class="page-header">
    <span class="header-micro header-micro--top-right">SYS://ALANI <span class="accent-dot" aria-hidden="true">●</span></span>
    <h1 class="page-title" data-scramble="load">Projects</h1>
    <p class="page-subtitle" data-scramble="load">// Active research initiatives</p>
    <span class="header-micro header-micro--bottom-left">REGISTRY: ACTIVE ◢ {new Date().getFullYear()}</span>
  </header>

  <div class="section-label" data-scramble="load">Active Research [{projects.length} projects]</div>

  <div class="project-list">
    {await Promise.all(projects.map(async (project) => {
      const { Content } = await project.render();
      return (
        <article class="project-card">
          <div class="corner-marks"></div>
          <div class="project-status">{project.data.status}</div>
          <h2 class="project-title" data-scramble="load">{project.data.title}</h2>
          <div class="project-body">
            <Content />
          </div>
          {project.data.targets && (
            <div class="project-targets">{project.data.targets}</div>
          )}
        </article>
      );
    }))}
  </div>
</Base>
